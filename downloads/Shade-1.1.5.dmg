        <script>
    var seconds = 60;
    var started = false;
    function display()
    {
        $('.btn-free-element').hide();
        $('.download-timer').show();
        if (seconds == 0)
        {
            $('.download-timer').html("<a class='btn' href='https://dasan.ir/yQft6?pt=eFNyNlpWd0Zza1dlNXhUUXFwcjR6MmhDWWpGalFtZHBkV2czVmpCcWNGTnpjMHBtUVZFOVBRPT0%3D'><span class='btn__text'>دانلود / مشاهده کنید</span></a>");
        } else
        {
            $('.download-timer-seconds').html(seconds);
        }
        seconds--;
    }
    
    function triggerFreeDownload() {
        if(started === true) {
            return;
        }
        
        started = true;
        display();
        countdownTimer = setInterval('display()', 1000);
    }

